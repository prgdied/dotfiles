#!/usr/bin/env bash

# ── Config ────────────────────────────────────────────────────────────────────
WALL_DIR="$HOME/Pictures/Wallpapers"
THEME="$HOME/.config/rofi/themes/wallpaper-switcher.rasi"
THUMB_DIR="$HOME/.cache/wallpaper-thumbs"
THUMB_SIZE="480x270"

BACKEND="${WALLPAPER_BACKEND:-awww}"
MODE="${1:-shallow}"

# ── Setup ─────────────────────────────────────────────────────────────────────
mkdir -p "$THUMB_DIR"

# ── Thumbnail generation ───────────────────────────────────────────────────────
get_thumb() {
    local src="$1"
    local hash
    hash=$(echo "$src" | md5sum | cut -d' ' -f1)
    local thumb="$THUMB_DIR/${hash}.png"

    if [ ! -f "$thumb" ]; then
        magick "${src}[0]" \
            -resize "${THUMB_SIZE}^" \
            -gravity Center \
            -extent "$THUMB_SIZE" \
            "$thumb" 2>/dev/null
    fi

    echo "$thumb"
}

# ── Wallpaper listing ──────────────────────────────────────────────────────────
list_wallpapers() {
    local find_args=("$WALL_DIR")

    if [ "$MODE" = "shallow" ]; then
        find_args+=(-maxdepth 1)
    fi

    find "${find_args[@]}" -type f \( \
        -iname "*.jpg" \
        -o -iname "*.jpeg" \
        -o -iname "*.png" \
        -o -iname "*.webp" \
        -o -iname "*.gif" \
    \) | sort | while read -r path; do
        local thumb
        thumb=$(get_thumb "$path")
        printf '%s\0icon\x1f%s\n' "$path" "$thumb"
    done
}

# ── Recache helper ─────────────────────────────────────────────────────────────
recache() {
    rm -rf "$THUMB_DIR"
    mkdir -p "$THUMB_DIR"
    notify-send "Wallpaper Switcher" "Cache cleared — reopen to reload." 2>/dev/null || true
}

# ── Apply wallpaper ────────────────────────────────────────────────────────────
apply_wallpaper() {
    local path="$1"
    case "$BACKEND" in
        awww)
            # --transition-duration is in seconds (0.3 = snappy 300ms wipe)
            awww img "$path" \
                --transition-type wipe \
                --transition-fps 60 \
                --transition-duration 0.8
            ;;
        swww)
            swww img "$path" \
                --transition-type wipe \
                --transition-fps 60 \
                --transition-duration 0.8
            ;;
        swaybg)    pkill swaybg; swaybg -i "$path" -m fill & ;;
        feh)       feh --bg-fill "$path" ;;
        hyprpaper) hyprctl hyprpaper wallpaper ",$path" ;;
        mpvpaper)  pkill mpvpaper; mpvpaper -o "no-audio loop" '*' "$path" & ;;
        wallutils) setwallpaper "$path" ;;
        *)         awww img "$path" --transition-type wipe --transition-fps 60 ;;
    esac
}

# ── Random wallpaper (always shallow — subfolders never included) ──────────────
if [ "$1" = "random" ]; then
    random_pick=$(find "$WALL_DIR" -maxdepth 1 -type f \( \
        -iname "*.jpg" \
        -o -iname "*.jpeg" \
        -o -iname "*.png" \
        -o -iname "*.webp" \
        -o -iname "*.gif" \
    \) | shuf -n 1)

    if [ -f "$random_pick" ]; then
        apply_wallpaper "$random_pick"
        wal -i "$random_pick"
    fi
    exit 0
fi

# ── Rofi keybindings ───────────────────────────────────────────────────────────
# Alt+s  → toggle shallow/deep subfolder mode (exit code 10)
# Alt+r  → wipe thumbnail cache and relaunch (exit code 11)

ROFI_OPTS=(
    -dmenu
    -theme "$THEME"
    -p ""
    -kb-custom-1 "alt+s"
    -kb-custom-2 "alt+r"
)

# ── Main ───────────────────────────────────────────────────────────────────────
choice=$(list_wallpapers | rofi "${ROFI_OPTS[@]}")
exit_code=$?

case $exit_code in
    0)
        if [ -f "$choice" ]; then
            apply_wallpaper "$choice"
            wal -i "$choice"
        fi
        ;;
    10)
        if [ "$MODE" = "shallow" ]; then
            exec bash "$0" deep
        else
            exec bash "$0" shallow
        fi
        ;;
    11)
        recache
        exec bash "$0" "$MODE"
        ;;
    *)
        exit 0
        ;;
esac
